# Windrose Monitor Environment Variables
# Copy this to .env and fill in your actual values
# .env is gitignored and will never be committed

# Pterodactyl Configuration
PTERODACTYL_API_URL=https://your-pterodactyl-panel.com
PTERODACTYL_API_TOKEN=your-api-token-here
PTERODACTYL_SERVER_ID=your-server-uuid-here
# Optional: overrides for websocket connection when the monitor runs on the same host
# Set PTERODACTYL_WEBSOCKET_HOST to the host:port to connect directly (e.g. 127.0.0.1:8080)
# Set PTERODACTYL_WEBSOCKET_ORIGIN to the expected Origin header (e.g. https://panel.example.com)
PTERODACTYL_WEBSOCKET_HOST=
PTERODACTYL_WEBSOCKET_ORIGIN=

# Discord Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Monitoring Configuration
CHECK_INTERVAL_SECONDS=20

# State/Log Files
STATE_FILE=/var/lib/windrose-monitor/state.json
LOG_FILE=/var/log/windrose-monitor.log
